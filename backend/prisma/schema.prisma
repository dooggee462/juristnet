generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Jurist {
  id                 String        @id @default(cuid())
  email              String        @unique
  passwordHash       String
  firstName          String
  lastName           String
  country            String
  postalCode         String
  streetAddress      String
  phoneNumber        String
  bio                String?       @db.Text
  areasOfExpertise   String[]
  spokenLanguages    String[]
  city               String?
  region             String?
  avatarUrl          String?
  isVerified         Boolean       @default(false)
  isActive           Boolean       @default(true)
  profileViews       Int           @default(0)
  phoneClicks        Int           @default(0)
  stripeCustomerId   String?       @unique
  stripeSubId        String?       @unique
  subStatus          SubStatus     @default(INACTIVE)
  subCurrentEnd      DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  listings           Listing[]
  reviews            Review[]
  messagesReceived   Message[]     @relation("ReceivedMessages")
  analytics          AnalyticsEvent[]
}

model Listing {
  id          String   @id @default(cuid())
  juristId    String
  title       String
  description String   @db.Text
  expertise   String[]
  languages   String[]
  city        String
  region      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jurist      Jurist   @relation(fields: [juristId], references: [id], onDelete: Cascade)
  reviews     Review[]
}

model Review {
  id        String   @id @default(cuid())
  listingId String
  juristId  String
  clientName String
  clientEmail String?
  rating    Int
  body      String   @db.Text
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  jurist    Jurist   @relation(fields: [juristId], references: [id], onDelete: Cascade)
}

model Message {
  id          String      @id @default(cuid())
  juristId    String
  senderName  String
  senderEmail String
  subject     String
  body        String      @db.Text
  isRead      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  jurist      Jurist      @relation("ReceivedMessages", fields: [juristId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String        @id @default(cuid())
  juristId  String
  type      EventType
  metadata  Json?
  createdAt DateTime      @default(now())
  jurist    Jurist        @relation(fields: [juristId], references: [id], onDelete: Cascade)
}

model StripeWebhookEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum EventType {
  PROFILE_VIEW
  PHONE_CLICK
  MESSAGE_SENT
  LISTING_VIEW
}
