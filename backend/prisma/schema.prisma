generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Expert {
  id                 String           @id @default(cuid())
  email              String           @unique
  passwordHash       String
  firstName          String
  lastName           String
  country            String
  postalCode         String
  streetAddress      String
  phoneNumber        String
  bio                String?          @db.Text
  category           String?
  areasOfExpertise   String[]
  spokenLanguages    String[]
  city               String?
  region             String?
  avatarUrl          String?
  isVerified         Boolean          @default(false)
  isActive           Boolean          @default(true)
  profileViews       Int              @default(0)
  phoneClicks        Int              @default(0)
  stripeCustomerId   String?          @unique
  stripeSubId        String?          @unique
  subStatus          SubStatus        @default(INACTIVE)
  subCurrentEnd      DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  listings           Listing[]
  reviews            Review[]
  messagesReceived   Message[]        @relation("ReceivedMessages")
  analytics          AnalyticsEvent[]
  conversations      Conversation[]
}

model Listing {
  id          String   @id @default(cuid())
  expertId    String
  title       String
  description String   @db.Text
  category    String?
  expertise   String[]
  languages   String[]
  city        String   @default("")
  region      String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expert      Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  reviews     Review[]
}

model Review {
  id          String   @id @default(cuid())
  listingId   String
  expertId    String
  clientName  String
  clientEmail String?
  rating      Int
  body        String   @db.Text
  createdAt   DateTime @default(now())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  expert      Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(cuid())
  expertId    String
  senderName  String
  senderEmail String
  subject     String
  body        String   @db.Text
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  expert      Expert   @relation("ReceivedMessages", fields: [expertId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String        @id @default(cuid())
  expertId     String
  clientName   String
  clientEmail  String
  lastMessage  String?       @db.Text
  lastAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  expert       Expert        @relation(fields: [expertId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@unique([expertId, clientEmail])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderType     SenderType
  senderName     String
  body           String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AnalyticsEvent {
  id        String    @id @default(cuid())
  expertId  String
  type      EventType
  metadata  Json?
  createdAt DateTime  @default(now())
  expert    Expert    @relation(fields: [expertId], references: [id], onDelete: Cascade)
}

model Category {
  id             String          @id @default(cuid())
  name           String          @unique
  slug           String          @unique
  subProfessions SubProfession[]
}

model SubProfession {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model StripeWebhookEvent {
  id        String   @id
  type      String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum EventType {
  PROFILE_VIEW
  PHONE_CLICK
  MESSAGE_SENT
  LISTING_VIEW
}

enum SenderType {
  CLIENT
  EXPERT
}
